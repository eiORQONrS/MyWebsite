---
import '../styles/global.css';
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${site.brand}` : site.title;
const pageDescription = description ?? site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/png" href="/uploads/cropped-me.png" />
    <link rel="canonical" href={site.url} />

    <!-- Preload the most-used font weights so first paint isn't FOUT -->
    <link rel="preload" href="/fonts/rubik-latin-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/rubik-latin-600.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="6f8957d4-979b-4ca3-80f9-2193a6b6451f"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="brand">
          {site.logoImage
            ? <img src={site.logoImage} alt={site.brand} class="brand-logo" />
            : site.brand}
        </a>
        <nav class="site-nav">
          {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">{site.footer}</div>
    </footer>

    <!--
      Mobile WeChat (X5 on Android, WKWebView on iOS) blocks <video autoplay>
      until the page has received a user gesture or until WeixinJSBridge is
      ready. Trigger play() on both signals so the autoplay UX matches every
      other browser. No effect outside WeChat mobile, since play() on an
      already-playing video is a no-op.
    -->
    <script is:inline>
      (function () {
        // .cn domain skips video activation entirely — Cloudflare-hosted MP4s
        // are unreliable from mainland China, so we leave the <video> elements
        // without a src and let the browser display the poster image as a
        // static fallback. Same build deploys to .com and .cn unchanged.
        var isCn = location.hostname.endsWith('.cn');

        function playAll() {
          if (isCn) return;
          document.querySelectorAll('video').forEach(function (v) {
            if (!v.src && v.dataset.src) v.src = v.dataset.src;
            // Play returns a promise; swallow rejections (autoplay denied).
            var p = v.play();
            if (p && typeof p.catch === 'function') p.catch(function () {});
          });
        }

        // Non-.cn: activate src on initial page load so autoplay still works.
        if (!isCn) {
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', playAll);
          } else {
            playAll();
          }
        }

        // .cn: scope click-to-play to publication cards only (project cards
        // already navigate on click, leave them alone). User clicks the poster
        // image, the video src is assigned and playback starts.
        function setupCnClickToPlay() {
          if (!isCn) return;
          document.querySelectorAll('.entry-media').forEach(function (media) {
            var video = media.querySelector('video[data-src]');
            if (!video) return;

            var overlay = document.createElement('button');
            overlay.type = 'button';
            overlay.className = 'video-play-overlay';
            overlay.setAttribute('aria-label', 'Play video');
            // Mirror the video's poster as a CSS background on the overlay so
            // it visually covers any flash of empty <video> content during the
            // poster→firstframe handoff (notably WeChat X5, which clears the
            // poster as soon as play() is called, before any frame is ready).
            var posterUrl = video.getAttribute('poster');
            if (posterUrl) overlay.style.backgroundImage = 'url("' + posterUrl + '")';
            overlay.innerHTML = '<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="32" cy="32" r="30" fill="rgba(0,0,0,0.55)"/><path d="M26 20 L46 32 L26 44 Z" fill="white"/></svg>';
            media.appendChild(overlay);

            overlay.addEventListener('click', function () {
              if (!video.src) video.src = video.dataset.src;
              video.preload = 'auto';

              // Disable further clicks but keep the overlay fully opaque over
              // the video. We only start the fade when the video is actually
              // rendering frames (the 'playing' event), which avoids the black
              // flash that happens between play() and the first decoded frame.
              overlay.style.pointerEvents = 'none';

              function onPlaying() {
                overlay.classList.add('is-hidden');
                // Drop the DOM node after the CSS opacity transition finishes
                // (matches the 0.25s value in global.css).
                setTimeout(function () { overlay.remove(); }, 300);
                video.removeEventListener('playing', onPlaying);
              }
              video.addEventListener('playing', onPlaying);

              // Safety net: if 'playing' never fires (broken video, blocked
              // network), still fade the overlay after a few seconds.
              setTimeout(function () {
                if (overlay.parentNode) onPlaying();
              }, 4000);

              var p = video.play();
              if (p && typeof p.catch === 'function') p.catch(function () {});
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setupCnClickToPlay);
        } else {
          setupCnClickToPlay();
        }

        // WeChat-specific: WeixinJSBridge unlocks autoplay-like APIs once ready.
        if (typeof WeixinJSBridge !== 'undefined') {
          playAll();
        } else {
          document.addEventListener('WeixinJSBridgeReady', playAll, false);
        }

        // Universal fallback: first user gesture anywhere on the page.
        var opts = { once: true, passive: true };
        ['touchstart', 'click'].forEach(function (evt) {
          document.addEventListener(evt, playAll, opts);
        });
      })();
    </script>
  </body>
</html>
