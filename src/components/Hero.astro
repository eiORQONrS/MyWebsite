---
import { site } from '../config';
const { hero } = site;
---

<script>
  const el = document.querySelector('.hero-name') as HTMLElement;
  if (el) {
    const text = el.textContent ?? '';
    el.textContent = '';

    const cursor = document.createElement('span');
    cursor.className = 'typewriter-cursor';
    el.appendChild(cursor);

    let i = 0;
    const type = () => {
      if (i < text.length) {
        el.insertBefore(document.createTextNode(text[i++]), cursor);
        setTimeout(type, 75);
      } else {
        setTimeout(() => {
          cursor.style.animation = 'none';
          cursor.style.opacity = '0';
        }, 1800);
      }
    };
    setTimeout(type, 300);
  }
</script>

<section id="home" class="section">
  <div class="container hero">
    <img src={hero.photo} alt="Yanjun Chen" class="hero-photo" />
    <div>
      <h1 class="hero-name">{hero.name}</h1>
      <p class="hero-bio" set:html={hero.bio} />
      <p class="hero-bio">{hero.interests}</p>
      <div class="hero-links">
        <a href={hero.cvUrl} class="hero-link-cv" target="_blank" rel="noopener" title="Download CV">CV</a>
        <a href={hero.googleScholarUrl} class="hero-link-scholar" target="_blank" rel="noopener" title="Google Scholar" aria-label="Google Scholar">
          <img src="/uploads/icons8-google-scholar.svg" alt="Google Scholar" />
        </a>
        <a href={hero.linkedinUrl} class="hero-link-linkedin" target="_blank" rel="noopener" title="LinkedIn" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/>
          </svg>
        </a>
        <a href={`mailto:${hero.email}`} class="hero-link-email" title="Send Email" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
