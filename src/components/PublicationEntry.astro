---
interface Props {
  title: string;
  authors: string; // may contain **name** for bold
  venue: string;
  paperUrl?: string;
  doiUrl?: string;
  videoUrl?: string;
  previewVideo?: string;
  award?: string;
}

const props = Astro.props;

// Convert **text** to <strong>text</strong> for the author line
const authorsHtml = props.authors.replace(
  /\*\*(.+?)\*\*/g,
  '<strong>$1</strong>'
);
---

<article class="entry">
  <div class="entry-media">
    {
      props.previewVideo ? (
        <video
          src={props.previewVideo}
          autoplay
          muted
          loop
          playsinline
          webkit-playsinline="true"
          x5-playsinline="true"
          x5-video-player-type="h5-page"
          controlsList="nodownload"
        />
      ) : null
    }
  </div>
  <div>
    <h3 class="entry-title">{props.title}</h3>
    <p class="entry-authors" set:html={authorsHtml} />
    <p class="entry-venue">{props.venue}</p>
    <div class="entry-links">
      {
        props.paperUrl && (
          props.paperUrl === 'soon'
            ? <span class="entry-link entry-link-disabled">paper</span>
            : <a href={props.paperUrl} class="entry-link" target="_blank" rel="noopener">paper</a>
        )
      }
      {
        props.doiUrl && (
          props.doiUrl === 'soon'
            ? <span class="entry-link entry-link-disabled">doi</span>
            : <a href={props.doiUrl} class="entry-link" target="_blank" rel="noopener">doi</a>
        )
      }
      {
        props.videoUrl && (
          <a href={props.videoUrl} class="entry-link" target="_blank" rel="noopener">
            video
          </a>
        )
      }
    </div>
    {props.award && <p class="entry-award">{props.award}</p>}
  </div>
</article>
