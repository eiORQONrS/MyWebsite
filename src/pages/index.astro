---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import News from '../components/News.astro';
import PublicationEntry from '../components/PublicationEntry.astro';
import ProjectEntry from '../components/ProjectEntry.astro';

// Pull all publications and sort by `order` field (ascending = newest first)
const publications = (await getCollection('publications')).sort(
  (a, b) => a.data.order - b.data.order
);

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base>
  <Hero />

  <section id="publication" class="section">
    <div class="container">
      <h2 class="section-title">Publications</h2>
      {
        publications.map((p) => (
          <PublicationEntry
            title={p.data.title}
            authors={p.data.authors}
            venue={p.data.venue}
            paperUrl={p.data.paperUrl}
            doiUrl={p.data.doiUrl}
            videoUrl={p.data.videoUrl}
            previewVideo={p.data.previewVideo}
            award={p.data.award}
          />
        ))
      }
    </div>
  </section>

  <section id="projects" class="section">
    <div class="container">
      <h2 class="section-title">Demonstrations</h2>
      <div class="projects-grid">
        {
          projects.map((p) => (
            <ProjectEntry
              title={p.data.title}
              venue={p.data.venue}
              image={p.data.image}
              award={p.data.award}
              projectUrl={p.data.projectUrl}
            />
          ))
        }
      </div>
    </div>
  </section>

  <News />
</Base>
